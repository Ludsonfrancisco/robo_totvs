PROTHEUS_URL=https://protheus.empresa.com.br/webapp/
PROTHEUS_USER=usuario.robo
PROTHEUS_PASS=troque-aqui

HEADLESS=false
VIEWPORT_W=1366
VIEWPORT_H=768
DOWNLOAD_TIMEOUT_S=60
TECNICOS_JSON=technicians.json

# Channel do navegador: "chrome" (Google Chrome do sistema) ou "chromium".
# Cloud TOTVS exige Chrome real para disparar download local — não trocar sem motivo.
BROWSER_CHANNEL=chrome
# Diretório do perfil persistente (cookies/permissões). Caminho relativo = dentro do projeto.
# Para reaproveitar perfil pessoal: ~/.config/google-chrome (feche o Chrome antes de rodar).
BROWSER_USER_DATA_DIR=.browser-profile/protheus
